[importlinter]
root_packages =
    generic_ml_cache_core
    generic_ml_cache_cli
    generic_ml_cache_daemon
    generic_ml_cache_adapters
include_external_packages = True

# Rule 1 — the application ring is independent of the adapter layer.
# Domain, use cases, and ports may not import from any adapter (inbound or outbound).
# This is the hexagonal invariant: dependencies point inward, never outward.
[importlinter:contract:hex-application-ring]
name = Application ring must not import adapters
type = forbidden
source_modules =
    generic_ml_cache_core.application
forbidden_modules =
    generic_ml_cache_adapters

# Rule 2 — driver packages (CLI, daemon) may only reach into adapters via their
# private composition modules.  They must not import driven adapter implementations
# (generic_ml_cache_adapters.adapter.out.*) from business-logic modules.
#
# ignore_imports lists the legitimate wiring edges in the private composition roots
# (_compose.py in CLI, inline wiring in daemon/app.py) and shared helpers:
#   * cli._compose is the CLI composition root — it is supposed to wire adapters.
#   * daemon.app is the daemon composition root — same.
#   * cli.composition provides get_encryption_state / load_cipher / build_store_encryptor.
#   * cli.controllers.daemon → daemon.app is an optional lazy import.
[importlinter:contract:hex-drivers-no-driven-adapters]
name = Driver packages must not import driven adapter implementations directly
type = forbidden
source_modules =
    generic_ml_cache_cli
    generic_ml_cache_daemon
forbidden_modules =
    generic_ml_cache_adapters.adapter.out
ignore_imports =
    # The bulk application wiring moved to generic_ml_cache_bootstrap (the
    # composition root), so the long list of _compose/app -> adapter.out edges is
    # gone. What remains are the few adapters the drivers still touch directly:
    # CLI encryption helpers (store encrypt/decrypt + the stub adapter for demos)
    generic_ml_cache_cli._compose -> generic_ml_cache_adapters.adapter.out.crypto.filesystem_encryption_manifest_store
    generic_ml_cache_cli._compose -> generic_ml_cache_adapters.adapter.out.crypto.store_encryptor
    generic_ml_cache_cli._compose -> generic_ml_cache_adapters.adapter.out.crypto.aesgcm_cipher
    generic_ml_cache_cli._compose -> generic_ml_cache_adapters.adapter.out.persistence.filesystem_store_lock
    generic_ml_cache_cli._compose -> generic_ml_cache_adapters.adapter.out.api.stub_api_client_adapter
    # CLI + daemon pick their own diagnostics adapter (logging is driver policy)
    generic_ml_cache_cli.composition -> generic_ml_cache_adapters.adapter.out.diagnostics.null_diagnostics_adapter
    generic_ml_cache_cli.composition -> generic_ml_cache_adapters.adapter.out.diagnostics.structlog_diagnostics_adapter
    generic_ml_cache_daemon.app -> generic_ml_cache_adapters.adapter.out.diagnostics.null_diagnostics_adapter
    generic_ml_cache_daemon.app -> generic_ml_cache_adapters.adapter.out.diagnostics.structlog_diagnostics_adapter
    # Optional daemon dependency — lazy import with ImportError guard in _cmd_daemon_start
    generic_ml_cache_cli.controllers.daemon -> generic_ml_cache_daemon.app

# Rule 3 — domain model purity.
# Domain objects (entities, value objects, domain events) must not import use cases,
# application services, OR ports. They are the innermost ring: they model the world,
# not the workflows, and not the boundaries that drive them. (A domain model leaking
# in from a port — e.g. ModelInfo via port/out/base — is the exact slip this catches.)
[importlinter:contract:hex-domain-purity]
name = Domain model must not import use cases or ports
type = forbidden
source_modules =
    generic_ml_cache_core.application.domain
forbidden_modules =
    generic_ml_cache_core.application.usecase
    generic_ml_cache_core.application.port

# Rule 3b — ports must not import use-case implementations.
# Ports are abstractions; use cases implement them. The arrow points one way:
# usecase -> port, never port -> usecase. (Composition containers that legitimately
# name use cases live in application.wiring, outside the port ring, not here.)
[importlinter:contract:hex-ports-no-usecases]
name = Ports must not import use cases
type = forbidden
source_modules =
    generic_ml_cache_core.application.port
forbidden_modules =
    generic_ml_cache_core.application.usecase

# Rule 4 — core must not import any specific database driver.
# Core is driver-agnostic: it accepts a DBAPI2 connection injected by the caller.
[importlinter:contract:no-db-driver-in-core]
name = Core must not import a database driver
type = forbidden
source_modules =
    generic_ml_cache_core
forbidden_modules =
    sqlite3

# Rule 5 — driven adapter sub-packages must not depend on each other.
# Each adapter knows only about the port interfaces it implements.
# Cross-adapter wiring happens exclusively in the composition roots.
[importlinter:contract:hex-adapter-isolation]
name = Driven adapter sub-packages must not import each other
type = independence
modules =
    generic_ml_cache_adapters.adapter.out.api
    generic_ml_cache_adapters.adapter.out.client
    generic_ml_cache_adapters.adapter.out.clock
    generic_ml_cache_adapters.adapter.out.crypto
    generic_ml_cache_adapters.adapter.out.fingerprint
    generic_ml_cache_adapters.adapter.out.gateway
    generic_ml_cache_adapters.adapter.out.metrics
    generic_ml_cache_adapters.adapter.out.persistence
    generic_ml_cache_adapters.adapter.out.storage
    generic_ml_cache_adapters.adapter.out.diagnostics
    generic_ml_cache_adapters.adapter.out.workspace

# Rule 6 — package-level isolation: lower packages never import driver packages.
# Adapters (infrastructure) and a driver must not reach "up" into another driver.
# Freezes the current clean state so accidental coupling can't creep in later.
[importlinter:contract:adapters-no-drivers]
name = Adapters must not import driver packages
type = forbidden
source_modules =
    generic_ml_cache_adapters
forbidden_modules =
    generic_ml_cache_cli
    generic_ml_cache_daemon

# Rule 7 — the daemon never imports the CLI (they are sibling drivers).
[importlinter:contract:daemon-not-cli]
name = Daemon must not import the CLI
type = forbidden
source_modules =
    generic_ml_cache_daemon
forbidden_modules =
    generic_ml_cache_cli

# Rule 8 — the CLI imports the daemon only through the optional lazy launcher
# (`gmlcache daemon start`), guarded by an ImportError so the daemon stays an
# optional dependency. No other CLI module may depend on the daemon.
[importlinter:contract:cli-not-daemon]
name = CLI must not import the daemon except the optional lazy launcher
type = forbidden
source_modules =
    generic_ml_cache_cli
forbidden_modules =
    generic_ml_cache_daemon
ignore_imports =
    generic_ml_cache_cli.controllers.daemon -> generic_ml_cache_daemon.app
